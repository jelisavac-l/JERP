{
  "serverName": "JERP Example Config",
  "services": [
    {
      "Name": "users-service",
      "path": "/api/users",
      "loadBalancingPolicy": "rr",
      "stripPrefix": true,
      "retries": 1,
      "timeout": 5,
      "instances": [
        {
          "url": "http://localhost:8081",
          "healthCheckPath": "/health"
        }
      ],
      "addHeaders": {
        "X-Some-Header": "Hello",
        "X-Some-Other-Header": "World"
      }
    },
    {
      "Name": "product-service",
      "path": "/api/products",
      "loadBalancingPolicy": "rr",
      "stripPrefix": true,
      "retries": 3,
      "timeout": 30,
      "instances": [
        {
          "url": "http://localhost:8082",
          "healthCheckPath": "/health"
        },
        {
          "url": "http://localhost:8083",
          "healthCheckPath": "/health"
        }
      ]
    }
  ]
}